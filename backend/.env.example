# Anthropic
ANTHROPIC_API_KEY=

# Vapi
VAPI_API_KEY=
VAPI_INTL_PHONE_NUMBER_ID=   # Twilio-backed Vapi number UUID — used for international calls (+972, etc.)
VAPI_PHONE_NUMBER_IDS=       # Comma-separated Vapi free number UUIDs — US calls, round-robin pool
VAPI_PHONE_NUMBERS=          # Comma-separated display strings matching VAPI_PHONE_NUMBER_IDS (e.g. +17864188381,+17864188460,...)
VAPI_WEBHOOK_SECRET=         # Optional — set to verify Vapi HMAC signatures on incoming webhooks

# Cal.com
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=

# Ngrok tunnel (restart ngrok → update this → restart backend)
WEBHOOK_BASE_URL=

# Optional security
DEBUG_SECRET=                # If set, /api/webhooks/debug requires ?secret=<this value>
